---
import { getCollection } from "astro:content";

// image paths
const Img1 = {
  src: "/assets/otty_kevin_optimized/2.png",
  srcsetWebp:
    "/assets/otty_kevin_optimized/2_optimized.webp 1x, /assets/otty_kevin_optimized/2_320w.webp 320w, /assets/otty_kevin_optimized/2_480w.webp 480w, /assets/otty_kevin_optimized/2_640w.webp 640w, /assets/otty_kevin_optimized/2_1024w.webp 1024w",
  srcsetAvif:
    "/assets/otty_kevin_optimized/2_optimized.avif 1x, /assets/otty_kevin_optimized/2_320w.avif 320w, /assets/otty_kevin_optimized/2_480w.avif 480w, /assets/otty_kevin_optimized/2_640w.avif 640w, /assets/otty_kevin_optimized/2_1024w.avif 1024w",
  webp: "/assets/otty_kevin_optimized/2_optimized.webp",
  avif: "/assets/otty_kevin_optimized/2_optimized.avif",
  fallback: "/assets/otty_kevin_optimized/2.png",
};
const Img2 = {
  src: "/assets/otty_kevin_optimized/6.png",
  srcsetWebp:
    "/assets/otty_kevin_optimized/6_optimized.webp 1x, /assets/otty_kevin_optimized/6_320w.webp 320w, /assets/otty_kevin_optimized/6_480w.webp 480w, /assets/otty_kevin_optimized/6_640w.webp 640w, /assets/otty_kevin_optimized/6_1024w.webp 1024w",
  srcsetAvif:
    "/assets/otty_kevin_optimized/6_optimized.avif 1x, /assets/otty_kevin_optimized/6_320w.avif 320w, /assets/otty_kevin_optimized/6_480w.avif 480w, /assets/otty_kevin_optimized/6_640w.avif 640w, /assets/otty_kevin_optimized/6_1024w.avif 1024w",
  webp: "/assets/otty_kevin_optimized/6_optimized.webp",
  avif: "/assets/otty_kevin_optimized/6_optimized.avif",
  fallback: "/assets/otty_kevin_optimized/6.png",
};
// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import Layout from "../layouts/Layout.astro";

// Component Imports
import CallToAction from "../components/CallToAction.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/reactJS/Icon";
import Pill from "../components/reactJS/Pill";
import PortfolioPreview from "../components/reactJS/PortfolioPreview";
import Contact from "../components/Contact.astro";
import Services from "../components/Services.astro";
import Card from "../components/card.astro";
import MenuLinkNav from "../components/menuLinkNav.astro";
// Page section components
import ContactCTA from "../components/ContactCTA.astro";
import Skills from "../components/reactJS/Skills";
import HeroMediaSocialNav from "../components/heroMediaSocialNav.astro";
import About from "../components/About.astro";
import Timeline from "../components/reactJS/TimelineExport";
import timelineEvents from "../data/timelineEvents.json";
// import HeroCounter from "../components/heroCounter.astro";

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/

import dataUser from "../data/User.json";
import { getLangFromCookies, getTranslations } from "../i18n/index";
import {
  applyPortfolioResponseHeaders,
  fetchPortfolioApiData,
  getPortfolioDataMode,
  getPortfolioRuntimeConfig,
  isApiRequiredMode,
} from "../lib/portfolio-data-source";

type ApiSkillRow = {
  name?: string | null;
  category?: string | null;
};

type ApiProjectRow = {
  id?: number | string;
  slug?: string | null;
  title?: string | null;
  description?: string | null;
  shortDescription?: string | null;
  featuredImage?: string | null;
  technologies?: unknown;
  projectUrl?: string | null;
  repositoryUrl?: string | null;
  sortOrder?: number | null;
  metadata?: unknown;
  isBeta?: boolean | null;
};

type ApiExperienceRow = {
  entryType?: string | null;
  title?: string | null;
  company?: string | null;
  description?: string | null;
  location?: string | null;
  startDate?: string | null;
  endDate?: string | null;
  companyUrl?: string | null;
};

type ApiProfileRow = {
  profileType?: string | null;
  fullName?: string | null;
  companyName?: string | null;
  headline?: string | null;
  bio?: string | null;
  email?: string | null;
  phone?: string | null;
  location?: string | null;
  websiteUrl?: string | null;
  availableForHire?: boolean | null;
  socialLinks?: Record<string, string> | null;
  sectorData?: {
    address?: {
      city?: string | null;
      country?: string | null;
      rue?: string | null;
      indicatif?: string | null;
    } | null;
    languages?: Record<string, unknown> | null;
  } | null;
};

type PortfolioEnvelope = {
  profile?: ApiProfileRow | null;
  skills?: ApiSkillRow[];
  projects?: ApiProjectRow[];
  experiences?: ApiExperienceRow[];
};

type HeroSocialLink = {
  label: string;
  href: string;
  icon: "twitter-logo" | "github-logo" | "youtube-logo" | "linkedin-logo" | "instagram-logo";
};

type ContactSocialLink = {
  label: string;
  href: string;
  platform: string;
};

type SkillCard = {
  title: string;
  icon: "pencil-line" | "code" | "terminal-window" | "github-logo";
  items: string[];
  color: string;
};

type PreviewProject = {
  id: string;
  slug: string;
  body: string;
  collection: string;
  data: {
    title: string;
    description: string;
    tech: string[];
    publishDate: Date;
    tags: string[];
    img: string;
    img_alt?: string;
    github?: string;
    liveDemo?: string;
    device?: string;
    additionalImages?: Array<{
      url: string;
      alt?: string;
    }>;
    isBeta?: boolean;
  };
  render: () => Promise<unknown>;
};

function isRecord(value: unknown): value is Record<string, unknown> {
  return Boolean(value) && typeof value === "object" && !Array.isArray(value);
}

function normalizeUrl(value?: string | null): string | undefined {
  if (!value) return undefined;
  const trimmed = value.trim();
  if (!trimmed) return undefined;
  if (/^(https?:|mailto:|tel:)/i.test(trimmed)) return trimmed;
  if (trimmed.startsWith("/")) return trimmed;
  return `https://${trimmed.replace(/^\/+/, "")}`;
}

function normalizeImage(value?: string | null): string {
  if (!value) return "/assets/social-preview.jpg";
  const trimmed = value.trim();
  if (!trimmed) return "/assets/social-preview.jpg";
  if (/^https?:\/\//i.test(trimmed) || trimmed.startsWith("/")) return trimmed;
  return `/${trimmed.replace(/^\/+/, "")}`;
}

function toStringArray(value: unknown): string[] {
  if (!Array.isArray(value)) return [];
  return value
    .map((entry) => (typeof entry === "string" ? entry.trim() : ""))
    .filter(Boolean);
}

function uniqueStrings(values: string[]): string[] {
  return Array.from(new Set(values.map((value) => value.trim()).filter(Boolean)));
}

function getSkillBuckets(skills: ApiSkillRow[]) {
  const buckets = {
    frameworks: [] as string[],
    databases: [] as string[],
    tools: [] as string[],
    design: [] as string[],
    maintenance: [] as string[],
  };

  for (const skill of skills) {
    const name = skill.name?.trim();
    if (!name) continue;
    const category = skill.category?.trim().toLowerCase() || "tools";
    if (category in buckets) {
      buckets[category as keyof typeof buckets].push(name);
    } else {
      buckets.tools.push(name);
    }
  }

  return Object.fromEntries(
    Object.entries(buckets).map(([key, value]) => [key, uniqueStrings(value)]),
  ) as typeof buckets;
}

function buildSkillCards(skills: ApiSkillRow[]): SkillCard[] {
  const fallbackSkills = dataUser.skills;
  const buckets =
    skills.length > 0
      ? getSkillBuckets(skills)
      : {
          frameworks: fallbackSkills.frameworks,
          databases: fallbackSkills.databases,
          tools: fallbackSkills.tools,
          design: fallbackSkills.design,
          maintenance: fallbackSkills.maintenance,
        };

  return [
    {
      title: "Design",
      icon: "pencil-line",
      items: buckets.design.length > 0 ? buckets.design : fallbackSkills.design,
      color: "from-purple-500 to-indigo-500",
    },
    {
      title: "Front-end",
      icon: "code",
      items:
        buckets.frameworks.length > 0 ? buckets.frameworks : fallbackSkills.frameworks,
      color: "from-blue-500 to-cyan-500",
    },
    {
      title: "Back-end",
      icon: "terminal-window",
      items:
        buckets.databases.length > 0 ? buckets.databases : fallbackSkills.databases,
      color: "from-emerald-500 to-teal-500",
    },
    {
      title: "Other",
      icon: "github-logo",
      items:
        uniqueStrings([...buckets.tools, ...buckets.maintenance]).length > 0
          ? uniqueStrings([...buckets.tools, ...buckets.maintenance])
          : uniqueStrings([...fallbackSkills.tools, ...fallbackSkills.maintenance]),
      color: "from-orange-500 to-red-500",
    },
  ];
}

function buildAboutSkills(skills: ApiSkillRow[]) {
  const fallbackSkills = dataUser.skills;
  const buckets =
    skills.length > 0
      ? getSkillBuckets(skills)
      : {
          frameworks: fallbackSkills.frameworks,
          databases: fallbackSkills.databases,
          tools: fallbackSkills.tools,
          design: fallbackSkills.design,
          maintenance: fallbackSkills.maintenance,
        };
  const mobileMatches = uniqueStrings(
    [...buckets.frameworks, ...buckets.tools].filter((skill) =>
      /react native|flutter|ios|android/i.test(skill),
    ),
  );

  return {
    webDev:
      buckets.frameworks.length > 0
        ? buckets.frameworks
        : fallbackSkills.frameworks,
    mobileDev:
      mobileMatches.length > 0
        ? mobileMatches
        : ["React Native", "Flutter", "iOS/Android Development"],
    other: uniqueStrings([
      ...buckets.databases,
      ...buckets.tools,
      ...buckets.design,
      ...buckets.maintenance,
    ]),
  };
}

function buildHeroSocialLinks(
  socialLinks: Record<string, string>,
): HeroSocialLink[] {
  const iconMap: Record<string, HeroSocialLink["icon"] | undefined> = {
    twitter: "twitter-logo",
    x: "twitter-logo",
    github: "github-logo",
    youtube: "youtube-logo",
    linkedin: "linkedin-logo",
    instagram: "instagram-logo",
  };
  const labelMap: Record<string, string> = {
    twitter: "Twitter",
    x: "Twitter",
    github: "GitHub",
    youtube: "YouTube",
    linkedin: "LinkedIn",
    instagram: "Instagram",
  };

  const orderedPlatforms = ["twitter", "github", "youtube", "linkedin", "instagram"];

  return orderedPlatforms
    .map((platform) => {
      const href = normalizeUrl(socialLinks[platform]);
      const icon = iconMap[platform];
      if (!href || !icon) return null;
      return {
        label: labelMap[platform],
        href,
        icon,
      };
    })
    .filter((link): link is HeroSocialLink => Boolean(link));
}

function buildContactSocialLinks(
  socialLinks: Record<string, string>,
): ContactSocialLink[] {
  const labelMap: Record<string, string> = {
    github: "GitHub",
    linkedin: "LinkedIn",
    pinterest: "Pinterest",
    instagram: "Instagram",
    youtube: "YouTube",
    twitter: "Twitter",
    x: "Twitter",
  };
  const orderedPlatforms = [
    "github",
    "linkedin",
    "pinterest",
    "instagram",
    "youtube",
    "twitter",
    "x",
  ];

  return orderedPlatforms
    .map((platform) => {
      const href = normalizeUrl(socialLinks[platform]);
      if (!href) return null;
      return {
        label: labelMap[platform] || platform,
        href,
        platform,
      };
    })
    .filter((link): link is ContactSocialLink => Boolean(link));
}

function normalizeTimelineEvent(row: ApiExperienceRow, index: number) {
  const startYear = row.startDate
    ? new Date(row.startDate).getFullYear()
    : new Date().getFullYear() - index;
  const category =
    row.entryType?.toLowerCase() === "education"
      ? "Formation"
      : "Professionnelle";

  return {
    year: startYear,
    title:
      category === "Professionnelle"
        ? row.company?.trim() || row.title?.trim() || "Experience"
        : row.title?.trim() || row.company?.trim() || "Formation",
    description:
      category === "Professionnelle"
        ? row.title?.trim() || ""
        : row.company?.trim() || "",
    details:
      row.description?.trim() ||
      row.location?.trim() ||
      timelineEvents[index]?.details ||
      "",
    category,
    image: timelineEvents[index]?.image,
    link: normalizeUrl(row.companyUrl),
  };
}

function normalizeProject(project: ApiProjectRow, index: number): PreviewProject {
  const metadata = isRecord(project.metadata) ? project.metadata : {};
  const tags = uniqueStrings(toStringArray(metadata.tags));
  const additionalImages = Array.isArray(metadata.additionalImages)
    ? metadata.additionalImages
        .map((image) => {
          if (!isRecord(image)) return null;
          const url = normalizeImage(
            typeof image.url === "string" ? image.url : undefined,
          );
          return {
            url,
            alt:
              typeof image.alt === "string"
                ? image.alt
                : project.title?.trim() || "Project image",
          };
        })
        .filter((image): image is { url: string; alt?: string } => Boolean(image))
    : [];
  const tech =
    uniqueStrings([
      ...toStringArray(project.technologies),
      ...toStringArray(metadata.tech),
    ]) || [];
  const device =
    typeof metadata.device === "string" && metadata.device.trim()
      ? metadata.device.trim().toLowerCase()
      : typeof metadata.projectType === "string" &&
          /mobile/i.test(metadata.projectType)
        ? "mobile"
        : "web";

  return {
    id: String(project.id ?? project.slug ?? `api-project-${index}`),
    slug: project.slug?.trim() || `api-project-${index}`,
    body: project.description?.trim() || project.shortDescription?.trim() || "",
    collection: "work",
    data: {
      title: project.title?.trim() || "Untitled project",
      description:
        project.shortDescription?.trim() ||
        project.description?.trim() ||
        "No description available.",
      tech,
      publishDate: new Date(),
      img: normalizeImage(project.featuredImage),
      img_alt: `${project.title?.trim() || "Project"} preview`,
      github: normalizeUrl(project.repositoryUrl),
      liveDemo: normalizeUrl(project.projectUrl),
      device,
      tags,
      isBeta: Boolean(project.isBeta || tags.some((tag) => /beta/i.test(tag))),
      additionalImages,
    },
    render: async () => ({}),
  };
}

const lang = getLangFromCookies(Astro.cookies);
const i18n = getTranslations(lang);
const portfolioRuntimeConfig = getPortfolioRuntimeConfig(Astro.url.origin);
const [localProjects, portfolioApiResult] = await Promise.all([
  getCollection("work"),
  fetchPortfolioApiData<PortfolioEnvelope>({
    path: `/api/portfolio/showcase/${portfolioRuntimeConfig.showcaseSlug}`,
    requestOrigin: Astro.url.origin,
  }),
]);
const apiPortfolio = portfolioApiResult.data;
const portfolioDataMode = getPortfolioDataMode();

const apiProfile = apiPortfolio?.profile ?? null;
const apiSkills = apiPortfolio?.skills ?? [];
const apiExperiences = apiPortfolio?.experiences ?? [];
const apiProjects = apiPortfolio?.projects ?? [];
if (isApiRequiredMode(portfolioDataMode)) {
  if (!apiProfile) {
    throw new Error("Portfolio API profile is required on homepage in api-required mode");
  }
  if (apiSkills.length === 0) {
    throw new Error("Portfolio API skills are required on homepage in api-required mode");
  }
  if (apiExperiences.length === 0) {
    throw new Error(
      "Portfolio API experiences are required on homepage in api-required mode",
    );
  }
  if (apiProjects.length === 0) {
    throw new Error("Portfolio API projects are required on homepage in api-required mode");
  }
}
const fallbackFullName = `${dataUser.firstName} ${dataUser.lastName}`;
const displayName =
  apiProfile?.companyName?.trim() ||
  apiProfile?.fullName?.trim() ||
  fallbackFullName;
const mergedSocialLinks = {
  ...dataUser.socialMedia,
  ...(apiProfile?.socialLinks ?? {}),
};
const heroSocialLinks = buildHeroSocialLinks(mergedSocialLinks);
const contactSocialLinks = buildContactSocialLinks(mergedSocialLinks);
const skillCards = buildSkillCards(apiSkills);
const aboutSkills = buildAboutSkills(apiSkills);
const profileLocation = apiProfile?.location?.trim() || dataUser.location;
const profileCity =
  apiProfile?.sectorData?.address?.city?.trim() ||
  profileLocation.split(",")[0]?.trim() ||
  dataUser.address.city;
const profileCountry =
  apiProfile?.sectorData?.address?.country?.trim() || dataUser.address.country;
const profilePhone = apiProfile?.phone?.trim() || dataUser.phone;
const profileEmail = apiProfile?.email?.trim() || dataUser.email;
const profileWebsite =
  normalizeUrl(apiProfile?.websiteUrl) || normalizeUrl(dataUser.website) || "";
const profileBio = apiProfile?.bio?.trim() || dataUser.profile;
const profileHeadline = apiProfile?.headline?.trim() || i18n.hero.tagline;
const profileAvailability =
  apiProfile?.availableForHire === false
    ? i18n.about.availability
    : i18n.contactCTA.available;
const profileLanguages =
  isRecord(apiProfile?.sectorData?.languages) &&
  Object.keys(apiProfile?.sectorData?.languages || {}).length > 0
    ? apiProfile?.sectorData?.languages
    : dataUser.languages;
const timelineData =
  apiExperiences.length > 0
    ? apiExperiences
        .map((experience, index) => normalizeTimelineEvent(experience, index))
        .sort((a, b) => b.year - a.year)
    : timelineEvents;
const projects =
  apiProjects.length > 0
    ? apiProjects
        .slice()
        .sort((a, b) => Number(b.sortOrder ?? 0) - Number(a.sortOrder ?? 0))
        .map((project, index) => normalizeProject(project, index))
        .slice(0, 4)
    : localProjects
        .sort((a, b) => b.data.number - a.data.number)
        .slice(0, 4);
applyPortfolioResponseHeaders(Astro.response.headers, {
  source: portfolioApiResult.resolvedSource,
  mode: portfolioDataMode,
  endpoint: portfolioApiResult.endpoint,
  requestOrigin: portfolioApiResult.requestOrigin,
  snapshotCapturedAt: portfolioApiResult.snapshotCapturedAt,
});

// import FilterProjects from "../components/reactJS/FilterProjects";
interface Props {
  heroTitle?: string | undefined;
}
const { heroTitle = `I am ${displayName}` } =
  Astro.props;
---

<Layout
  title={`${displayName} - ${i18n.meta.homeTitle}`}
  description={i18n.meta.homeDescription.replace('{firstName}', displayName).replace('{lastName}', "").replace('{city}', profileCity)}
  image="/assets/social-preview.jpg"
  type="website"
>
  <MenuLinkNav namepage="home" />

  <!-- Modern Hero Section -->
  <section id="hero_home">
    <Hero
      title={heroTitle}
      tagline={profileHeadline}
      tagline1={i18n.hero.tagline1}
      align="center"
    >
      <!-- Hero Image — editorial photo treatment -->
      <div class="hero-image-modern" slot="photo">
        <div class="image-wrapper">
          <picture>
            <source
              srcset={Img1.srcsetAvif}
              type="image/avif"
              sizes="100px"
            />
            <source
              srcset={Img1.srcsetWebp}
              type="image/webp"
              sizes="100px"
            />
            <img
              alt={`${displayName}, ${i18n.meta.imgAlt.replace('{city}', profileCity).replace('{country}', profileCountry)}`}
              width="100"
              height="100"
              src={Img1.fallback}
              loading="eager"
              decoding="async"
            />
          </picture>
        </div>
      </div>

      <!-- Social Media Navigation -->
      <div class="hero-social-modern" slot="social">
        <HeroMediaSocialNav links={heroSocialLinks} />
      </div>
    </Hero>
  </section>

  <main class="wrapper stack gap-20 lg:gap-35">
    <Skills client:visible skillsData={skillCards} />
  </main>
  <main id="about" class="wrapper stack gap-20 lg:gap-35">
    <About
      imageSrc={Img2}
      optimizedImageSrc={{
        avif: Img2.avif,
        webp: Img2.webp,
        fallback: Img2.fallback,
        srcsetAvif: Img2.srcsetAvif,
        srcsetWebp: Img2.srcsetWebp,
      }}
      description={profileBio}
      skills={aboutSkills}
      languages={[
        { name: i18n.languages.french, level: typeof profileLanguages.french === "string" ? profileLanguages.french : i18n.languages.native, percentage: 100 },
        {
          name: i18n.languages.english,
          level: isRecord(profileLanguages.english)
            ? Object.values(profileLanguages.english)
                .filter((value) => typeof value === "string")
                .join(" / ")
            : typeof profileLanguages.english === "string"
              ? profileLanguages.english
              : i18n.languages.professional,
          percentage: 70,
        },
      ]}
      contactInfo={{
        city: profileCity,
        street: apiProfile?.sectorData?.address?.rue?.trim() || dataUser.address.rue,
        email: profileEmail,
        phone: profilePhone,
        phonePrefix:
          apiProfile?.sectorData?.address?.indicatif?.trim() ||
          dataUser.address.indicatif,
        occupation: profileHeadline || i18n.about.occupation,
        availability: profileAvailability,
        website: profileWebsite.replace(/^https?:\/\//, ""),
      }}
    />
  </main>
  <section id="journey" class="journey-band">
    <div class="wrapper stack gap-20 lg:gap-35">
      <Timeline
        client:visible
        title={i18n.timeline.title}
        subtitle={i18n.timeline.subtitle}
        events={timelineData}
      />
    </div>
  </section>

  <div class="wrapper stack gap-20 lg:gap-35">
    <Services />
    <section id="work" class="section with-background with-cta">
      <header class="section-header stack gap-2 lg:gap-4">
        <h2>{i18n.projects.title}</h2>
        <p>
          {i18n.projects.description}
        </p>
      </header>

      <div class="gallery">
        <Card>
          {
            projects.map((project) => (
              <li>
                <PortfolioPreview project={project} client:visible />
              </li>
            ))
          }
        </Card>
      </div>

      <div class="cta">
        <CallToAction href="/work/">
          {i18n.projects.viewAll}
          <Icon icon="arrow-right" size="1.2em" />
        </CallToAction>
      </div>
    </section>
  </div>

  <ContactCTA
    contactInfo={{
      email: profileEmail,
      phone: profilePhone,
      website: profileWebsite.replace(/^https?:\/\//, ""),
      location: profileLocation,
    }}
    socialLinks={contactSocialLinks}
    availabilityLabel={profileAvailability}
  />
</Layout>

<style>
  /* Hero Image — flexible sizing for identity card photo mask */
  .hero-image-modern {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .image-wrapper :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* Social wrapper — reset positioning for sidebar slot */
  .hero-social-modern {
    display: contents;
  }

  /* ====================================================== */

  .section {
    display: grid;
    gap: 2rem;
  }

  .with-background {
    position: relative;
  }

  .with-background::before {
    --hero-bg: var(--bg-image-subtle-2);

    content: "";
    position: absolute;
    pointer-events: none;
    left: 50%;
    width: 100vw;
    aspect-ratio: calc(2.25 / var(--bg-scale));
    top: 0;
    transform: translateY(-75%) translateX(-50%);
    background:
      url("/assets/backgrounds/noise.png") top center/220px repeat,
      var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
      var(--gray-999);
    background-blend-mode: overlay, normal, normal, normal;
    mix-blend-mode: var(--bg-blend-mode);
    z-index: -1;
  }

  .with-background.bg-variant::before {
    --hero-bg: var(--bg-image-subtle-1);
  }

  .section-header {
    justify-self: center;
    text-align: center;
    max-width: 50ch;
    font-size: var(--text-md);
    color: var(--gray-300);
  }

  .section-header h3 {
