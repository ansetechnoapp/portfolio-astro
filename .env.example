# Variables d'environnement principales pour le portfolio Astro
# Copiez ce fichier vers .env et adaptez les valeurs locales.

# Source de données du portfolio :
# - prefer-api   => essaie l'API puis fallback local
# - api-required => interdit le fallback local
# - local-only   => n'utilise jamais l'API
PORTFOLIO_DATA_MODE=api-required

# URL de l'API ZodBack d'integration canonique
PORTFOLIO_API_BASE_URL=https://integrations-api.zodev.live

# Origin attendu côté ZodBack si vous ne laissez pas le runtime envoyer l'origine réelle
PORTFOLIO_API_ORIGIN=https://my.zodev.live

# Token projet côté serveur uniquement
PORTFOLIO_API_TOKEN=zb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slug du showcase portfolio à charger
PORTFOLIO_SHOWCASE_SLUG=main-portfolio

# Variables SEO / verification
PUBLIC_GOOGLE_SITE_VERIFICATION=votre-code-google-search-console